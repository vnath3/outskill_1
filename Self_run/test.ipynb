   "source": [
    "import math\n",
    "\n",
    "def calculate_area_of_circle(radius):\n",
    "    if radius < 0:\n",
    "        raise ValueError(\"Radius cannot be negative\")\n",
    "    return math.pi * radius ** 2\n",
    "\n",
    "\n",
    "\n",
    "result = calculate_area_of_circle(5)\n",
    "    print(f\"The area of circle is {result}\")\n",
    "\n",
    "\n",
    "\n"
   ]
  }
